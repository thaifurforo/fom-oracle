# FOM Oracle — Variaveis de Ambiente
#
# Copie este arquivo para .env e ajuste os valores conforme necessario.
# Apenas variaveis com valor preenchido sao lidas pelo app.

# Caminho da pasta de saves do jogo (override da deteccao automatica)
# FOM_SAVE_PATH=C:\Users\SeuUsuario\AppData\Local\FieldsOfMistria\Saves

# Caminho da instalacao do jogo (override da deteccao automatica)
# FOM_GAME_PATH=C:\Program Files\Steam\steamapps\common\Fields of Mistria

# Porta do sidecar .NET (padrao: 5000)
# FOM_API_PORT=5000

# Nivel de logging (Verbose, Debug, Information, Warning, Error)
# FOM_LOG_LEVEL=Information

# Diretorio de dados do app (snapshots, preferencias, catalogos)
# Por padrao: %APPDATA%\FomOracle
# FOM_DATA_DIR=
