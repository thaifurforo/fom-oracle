{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FOM Oracle",
  "version": "0.1.0",
  "identifier": "com.fomoracle.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir .. dev:web",
    "beforeBuildCommand": "pnpm --dir .. build:web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FOM Oracle",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
